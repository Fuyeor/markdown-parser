    "build": "vite build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0"
  }
}
